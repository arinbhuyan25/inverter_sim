# ─────────────────────────────────────────────
# Modbus ↔ MQTT Bridge — Environment Variables
# ─────────────────────────────────────────────

# ── ThingsBoard (main telemetry device) ──────
THINGSBOARD_ACCESS_TOKEN=HfhzLcqDh5yBmuVWDbgt

# ── ThingsBoard (mobile alert device) ───────
# We will use the same token for alerts for now so it all goes to one device
ALERT_DEVICE_TOKEN=HfhzLcqDh5yBmuVWDbgt

# ── MQTT Broker ──────────────────────────────
MQTT_HOST=eu.thingsboard.cloud
MQTT_PORT=1883

# ── Device identity ──────────────────────────
DEVICE_ID=INV_001

# ── Modbus Simulator ─────────────────────────
MODBUS_HOST=localhost
MODBUS_PORT=5020
MODBUS_UNIT_ID=1

# ── Polling interval (seconds) ───────────────
POLL_INTERVAL=2
