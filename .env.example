# ─────────────────────────────────────────────
# Modbus ↔ MQTT Bridge — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── ThingsBoard (main telemetry device) ──────
THINGSBOARD_ACCESS_TOKEN=YOUR_DEVICE_ACCESS_TOKEN_HERE

# ── ThingsBoard (mobile alert device) ───────
# Create a second virtual device in ThingsBoard for mobile alerts.
# If you only have one device, set this to the same token as above.
ALERT_DEVICE_TOKEN=YOUR_ALERT_DEVICE_TOKEN_HERE

# ── MQTT Broker ──────────────────────────────
# ThingsBoard Cloud: mqtt.thingsboard.cloud:1883
# Self-hosted:       your-server-ip:1883
# Local Mosquitto:   localhost:1883
MQTT_HOST=mqtt.thingsboard.cloud
MQTT_PORT=1883

# ── Device identity ──────────────────────────
DEVICE_ID=INV_001

# ── Modbus Simulator ─────────────────────────
MODBUS_HOST=localhost
MODBUS_PORT=5020
MODBUS_UNIT_ID=1

# ── Polling interval (seconds) ───────────────
POLL_INTERVAL=2
